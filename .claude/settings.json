{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // empty' | xargs -I {} bash -c '[[ \"{}\" == *.dart ]] && dart format \"{}\" 2>/dev/null || true'"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)",
      "Bash(git show*)",
      "Bash(git stash list*)",
      "Bash(git worktree list*)",
      "Bash(git submodule*)",
      "Bash(ls*)",
      "Bash(pwd)",
      "Bash(which*)",
      "Bash(wc*)",
      "Bash(melos *)",
      "Bash(flutter *)",
      "Bash(dart *)",
      "Bash(fvm *)",
      "Bash(cargo *)",
      "Bash(pod *)",
      "Bash(gh *)"
    ],
    "deny": []
  }
}
